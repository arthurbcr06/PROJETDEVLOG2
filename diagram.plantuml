@startuml
class GestionnaireFormulaires {
  fr.eseo.e3e.projet2.app
  --
  - formulaires: List<Formulaire>
  - epreuves: List<Epreuve>
  --
  + GestionnaireFormulaires(): 
  + getFormulaires(): List<Formulaire>
  + setFormulaires(List<Formulaire>): void
  + getEpreuves(): List<Epreuve>
  + setEpreuves(List<Epreuve>): void
  + ajouterFormulaire(Formulaire): void
  + supprimerFormulaire(int): void
  + ajouterEpreuve(Epreuve): void
  + getFormulairesParEtudiant(int): List<Formulaire>
  + getFormulairesParEpreuve(String): List<Formulaire>
  + rechercherParNom(String): List<Etudiant>
  + rechercherParPrenom(String): List<Etudiant>
  + trouverParNumero(int): Etudiant
  + calculerStatistiques(): void
  + afficherGraphe(): void
  + detecterRecidivistes(): List<Etudiant>
}

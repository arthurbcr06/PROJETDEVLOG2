  + E5: Cursus
  + B1: Cursus
  + B2: Cursus
  + B3: Cursus
  --
  + values(): Cursus[]
  + valueOf(String): Cursus
  - Cursus(): 
}
class Epreuve {
  fr.eseo.e3e.projet2.formulaires
  --
  - codeECUE: String
  - datePassage: LocalDate
  - heurePassage: LocalTime
  - dureePassage: Duration
  - modalite: Modalite
  --
  + Epreuve(): 
  + Epreuve(String, LocalDate, LocalTime, Duration, Modalite): 
  + getCodeECUE(): String
  + setCodeECUE(String): void
  + getDatePassage(): LocalDate
  + setDatePassage(LocalDate): void
  + getHeurePassage(): LocalTime
  + setHeurePassage(LocalTime): void
  + getDureePassage(): Duration
  + setDureePassage(Duration): void
  + getModalite(): Modalite
  + setModalite(Modalite): void
}
class Etudiant {
  fr.eseo.e3e.projet2.formulaires
  --
  - nom: String
  - prenom: String
  - numeroApprenant: int
  - cursus: Cursus
  --
  + Etudiant(): 
  + Etudiant(String, String, int, Cursus): 
  + getNom(): String
  + setNom(String): void
  + getPrenom(): String
  + setPrenom(String): void
  + getNumeroApprenant(): int
  + getCursus(): Cursus
  + setCursus(Cursus): void
  + setNumeroApprenant(int): void
  + equals(Object): boolean
  + hashCode(): int
}
class Formulaire {
  fr.eseo.e3e.projet2.formulaires
  --
  - compteur: int
  - identifiantNumeriqueUnique: int
  - dateCreation: LocalDate
  - dateDerniereModification: LocalDate
  - epreuve: Epreuve
  - sanction: Sanction
  - etudiants: List<Etudiant>
  - fraudes: List<Fraude>
  --
  + Formulaire(): 
  + Formulaire(Epreuve, List<Etudiant>, List<Fraude>, Sanction): 
  + ajouterEtudiant(Etudiant): void
  + ajouterFraude(Fraude): void
  + getSanction(): Sanction
  + getEtudiants(): List<Etudiant>
  + getFraudes(): List<Fraude>
  + getEpreuve(): Epreuve
  + getDateDerniereModification(): LocalDate
  + getIdentifiantNumeriqueUnique(): int
  + getDateCreation(): LocalDate
  + setSanction(Sanction): void
  + setEpreuve(Epreuve): void
}
